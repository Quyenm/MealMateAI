# ─── MealMate AI — environment variables ───
# Copy to .env.local and fill in. NEVER commit .env.local.
# RULE: secrets must NOT have the NEXT_PUBLIC_ prefix (that ships them to the browser).
# lib/env.ts asserts this at boot.

# ── Public (safe in browser; NEXT_PUBLIC_ prefix) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Server-only secrets (NO NEXT_PUBLIC_ prefix) ──
# OpenAI (vision + recipe). Set a hard billing cap in the OpenAI dashboard.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase service role (bypasses RLS — server only, guard carefully)
SUPABASE_SERVICE_ROLE_KEY=

# Global daily spend circuit-breaker ceiling (USD) — amount you can afford to lose
GLOBAL_DAILY_SPEND_CAP_USD=5

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (bot defense on signup)
TURNSTILE_SECRET_KEY=

# PayOS (added in M4 — VietQR/Momo/ZaloPay)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Base URL used for PayOS return/webhook URLs
APP_BASE_URL=http://localhost:3000
